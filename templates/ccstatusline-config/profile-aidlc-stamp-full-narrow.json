    "L1-model (redundant with L3-model)",
    "L1-stage (SFIF carries the phase signal already)",
    "L3-session-name (rarely needed at-a-glance)",
    "L3-thinking (model-meta detail)",
    "L3-vim (low-priority indicator)",
    "L4-weeklyusage (session-usage carries the spend signal)",
    "L4-sescost (already in usage widget context)"
  ],
